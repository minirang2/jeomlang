{
  "env": {
    "browser": true,
    "es2024": true,
    "node": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "eqeqeq": "error",
    "no-undef": "error",
    "no-unreachable": "error",
    "no-unused-vars": ["warn", { "args": "none" }],
    "no-async-promise-executor": "error"
  }
}
