{
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "outDir": "./ide/dist",
    "esModuleInterop": true
  },
  "include": ["ide/src/**/*"],
  "exclude": ["node_modules"]
}
